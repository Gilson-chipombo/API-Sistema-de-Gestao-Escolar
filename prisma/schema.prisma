generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id_usuario Int           @id @default(autoincrement())
  user_name  String
  email      String        @unique
  password   String
  perfil     PerfilUsuario
  status     StatusUsuario
  created_at DateTime      @default(now())
  deleted_at DateTime?
  avisos     Aviso[]
  professor  Professor?
}

model Professor {
  id_prof                Int                   @id @default(autoincrement())
  nome_prof              String
  filiacao_prof          String?
  data_nascimento_prof   DateTime              @db.Date
  email_prof             String?
  telefone_prof          String
  numero_bi_prof         String                @unique
  data_emissao_bi_prof   DateTime              @db.Date
  nacionalidade_prof     String?
  endereco_fisico_prof   String
  naturalidade_prof      String
  nivel_academico        NivelAcademico
  area_formacao_prof     String
  ano_conclusao_formacao Int?
  data_admissao          DateTime?             @db.Date
  status                 StatusProfessor
  created_at             DateTime              @default(now())
  updated_at             DateTime              @updatedAt
  usuario_id             Int?                  @unique
  usuario                Usuario?              @relation(fields: [usuario_id], references: [id_usuario])
  disciplinas            ProfessorDisciplina[]
  turmas                 ProfessorTurma[]
  turmas_dirigidas       Turma[]
}

model Curso {
  id_curso          Int               @id @default(autoincrement())
  sigla_curso       String            @unique
  descricao_curso   String
  created_at        DateTime          @default(now())
  updated_at        DateTime          @updatedAt
  duracao_semestres Int?
  disciplinas       CursoDisciplina[]
  turmas            Turma[]
}

model Turma {
  id_turma           Int              @id @default(autoincrement())
  sigla_turma        String
  ano_lectivo_turma  Int
  turno_turma        String
  classe_turma       String
  sala_turma         String
  numero_aluno_turma Int?
  observacoes_turma  String?
  created_at         DateTime         @default(now())
  updated_at         DateTime         @updatedAt
  curso_id           Int?
  diretor_turma      Int
  estudantes         Estudante[]
  faltas             Falta[]
  notas              Nota[]
  professores        ProfessorTurma[]
  curso              Curso?           @relation(fields: [curso_id], references: [id_curso])
  diretor            Professor        @relation(fields: [diretor_turma], references: [id_prof])
}

model Estudante {
  id_estudante              Int             @id @default(autoincrement())
  nome_estudante            String
  data_nascimento           DateTime        @db.Date
  nome_pai_estudante        String?
  nome_mae_estudante        String?
  naturalidade_estudante    String
  numero_bi_estudante       String          @unique
  telefone_estudante        String?
  endereco_fisico_estudante String
  encarregado_estudante     String?
  data_cadastro             DateTime?       @db.Date
  status                    StatusEstudante
  created_at                DateTime        @default(now())
  updated_at                DateTime        @updatedAt
  turma_id                  Int?
  turma                     Turma?          @relation(fields: [turma_id], references: [id_turma])
  faltas                    Falta[]
  notas                     Nota[]
}

model Disciplina {
  id_disc        Int                   @id @default(autoincrement())
  sigla_disc     String                @unique
  descricao_disc String
  created_at     DateTime              @default(now())
  updated_at     DateTime              @updatedAt
  cursos         CursoDisciplina[]
  faltas         Falta[]
  notas          Nota[]
  professores    ProfessorDisciplina[]
}

model CursoDisciplina {
  id            Int        @id @default(autoincrement())
  curso_id      Int
  disciplina_id Int
  ordem         Int?
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt
  curso         Curso      @relation(fields: [curso_id], references: [id_curso], onDelete: Cascade)
  disciplina    Disciplina @relation(fields: [disciplina_id], references: [id_disc], onDelete: Cascade)

  @@unique([curso_id, disciplina_id])
}

model Nota {
  id_nota        Int        @id @default(autoincrement())
  trimestre_nota Decimal?   @db.Decimal(5, 2)
  data_nota      DateTime?  @db.Date
  mac_notas      Decimal?   @db.Decimal(5, 2)
  pp_notas       Decimal?   @db.Decimal(5, 2)
  pt_notas       Decimal?   @db.Decimal(5, 2)
  ano_letivo     Int?
  observacao     String?
  created_at     DateTime   @default(now())
  updated_at     DateTime   @updatedAt
  estudante_id   Int
  disciplina_id  Int
  turma_id       Int
  disciplina     Disciplina @relation(fields: [disciplina_id], references: [id_disc], onDelete: Cascade)
  estudante      Estudante  @relation(fields: [estudante_id], references: [id_estudante], onDelete: Cascade)
  turma          Turma      @relation(fields: [turma_id], references: [id_turma], onDelete: Cascade)
}

model Falta {
  id_falta      Int        @id @default(autoincrement())
  data_falta    DateTime   @db.Date
  tipo_falta    TipoFalta
  observacao    String?
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt
  estudante_id  Int
  disciplina_id Int
  turma_id      Int
  disciplina    Disciplina @relation(fields: [disciplina_id], references: [id_disc], onDelete: Cascade)
  estudante     Estudante  @relation(fields: [estudante_id], references: [id_estudante], onDelete: Cascade)
  turma         Turma      @relation(fields: [turma_id], references: [id_turma], onDelete: Cascade)
}

model Aviso {
  id              Int               @id @default(autoincrement())
  titulo          String
  conteudo        String
  destinatarios   DestinatarioAviso
  data_publicacao DateTime
  data_expiracao  DateTime?         @db.Date
  prioridade      PrioridadeAviso
  created_at      DateTime          @default(now())
  updated_at      DateTime          @updatedAt
  professor_id    Int?
  professor       Usuario?          @relation(fields: [professor_id], references: [id_usuario])
}

model ProfessorDisciplina {
  id            Int        @id @default(autoincrement())
  professor_id  Int
  disciplina_id Int
  created_at    DateTime   @default(now())
  disciplina    Disciplina @relation(fields: [disciplina_id], references: [id_disc], onDelete: Cascade)
  professor     Professor  @relation(fields: [professor_id], references: [id_prof], onDelete: Cascade)

  @@unique([professor_id, disciplina_id])
}

model ProfessorTurma {
  id           Int       @id @default(autoincrement())
  professor_id Int
  turma_id     Int
  created_at   DateTime  @default(now())
  professor    Professor @relation(fields: [professor_id], references: [id_prof], onDelete: Cascade)
  turma        Turma     @relation(fields: [turma_id], references: [id_turma], onDelete: Cascade)

  @@unique([professor_id, turma_id])
}

enum PerfilUsuario {
  ADMIN
  PROFESSOR
  ESTUDANTE
  SECRETARIA
}

enum StatusUsuario {
  ATIVO
  INATIVO
  SUSPENSO
}

enum NivelAcademico {
  LICENCIATURA
  MESTRADO
  DOUTORAMENTO
  BACHARELATO
  OUTRO
}

enum StatusProfessor {
  ATIVO
  INATIVO
  LICENCA
}


enum StatusEstudante {
  ATIVO
  INATIVO
  TRANSFERIDO
  CONCLUIDO
}

enum TipoFalta {
  JUSTIFICADA
  INJUSTIFICADA
}

enum DestinatarioAviso {
  TODOS
  ADMIN
  PROFESSORES
  ESTUDANTES
  PAIS
}

enum PrioridadeAviso {
  BAIXA
  MEDIA
  ALTA
  URGENTE
}
